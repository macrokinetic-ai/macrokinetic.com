# MacroKinetic — environment variables
#
# Copy this file to `.env.local` (gitignored) for local dev, and add the same
# keys in your host (Vercel) for preview/production. Only the contact form
# (/api/contact + ContactForm) reads these — the rest of the site needs none.
#
# Legend:  [REQUIRED] form won't send without it · [optional] has a safe default

# ── Contact Form — SMTP (outgoing mail) ───────────────────────────────────────
# Without HOST/USER/PASS the form returns a 503 "email us directly" message.
SMTP_HOST=smtp.example.com          # [REQUIRED] e.g. smtp.gmail.com, smtp.zoho.eu
SMTP_USER=username                  # [REQUIRED] SMTP account / login
SMTP_PASS=password                  # [REQUIRED] SMTP password or app-specific token
SMTP_PORT=587                       # [optional] default 587 (STARTTLS) · use 465 for TLS
SMTP_SECURE=false                   # [optional] default false · set "true" for port 465
SMTP_FROM=website@macrokinetic.com  # [optional] default website@macrokinetic.com
# Enquiries are delivered to enquiry@macrokinetic.com (hard-coded in the route).

# ── Contact Form — Cloudflare Turnstile (bot protection) ──────────────────────
# Free keys at https://dash.cloudflare.com/ → Turnstile.
# The values below are Cloudflare's TEST keys: they always pass and are fine for
# local dev, but give NO real protection — replace both for production.
# NEXT_PUBLIC_* is inlined at BUILD time, so it must be set before the prod build.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA          # [optional] public site key
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA         # [optional] server secret; if unset, captcha is skipped
